# Private / testing
tests/

# tagging-real-world/ publishes the pipeline itself (build.sh, README) but
# the real test corpus stays local. Per-example folders, output dirs, and
# stray *.tex / image trees underneath examples/ are gitignored.
tagging-real-world/examples/
tagging-real-world/**/tagged_output/

# Claude Code per-machine state
.claude/
CLAUDE.local.md

# playwright-cli session artifacts (lands wherever the CLI is invoked)
.playwright-cli/

# OS / editor cruft
.DS_Store
Thumbs.db
*~
.#*
\#*\#
*.swp
*.swo

# Jekyll local-preview output
_site/
.jekyll-cache/

# Per-pipeline build artifacts are handled by each subdirectory's own .gitignore
# (tagging/.gitignore, latexml/.gitignore, tex4ht/.gitignore, markdown/.gitignore,
# docs/.gitignore).
